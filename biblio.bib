@article{DWSwEEFUtDIwtAMfBaGAR_Butt_2024,
  title = {Dielectric {{Waveguide-Based Sensors}} with {{Enhanced Evanescent Field}}: {{Unveiling}} the {{Dynamic Interaction}} with the {{Ambient Medium}} for {{Biosensing}} and {{Gas-Sensing Applications}}---{{A Review}}},
