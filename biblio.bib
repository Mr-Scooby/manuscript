@article{Advioews_BrandenburgEtAl_1995,
  title = {Ammonia Detection via Integrated Optical Evanescent Wave Sensors},
  author = {Brandenburg, Albrecht and Edelh{\"a}user, Rainer and Werner, Tobias and He, Huarui and Wolfbeis, Otto S.},
  year = 1995,
  month = mar,
  journal = {Microchimica Acta},
  volume = {121},
  number = {1},
  pages = {95--105},
  issn = {1436-5073},
  doi = {10.1007/BF01248244},
  urldate = {2025-12-04},
  abstract = {Detection of ammonia in the gas phase by means of integrated optical components, coated with sensitive films which reversibly change their spectral absorption with ammonia concentration, is demonstrated. The evanescent wave of the guided light continuously probes the absorbance of the sensor membrane at 633 nm. The output intensity is compared with that of a reference channel not influenced by the sensitive film. With Bromocresol Green and Bromophenol Blue in silicone as indicators, ammonia levels of less than 1 ppm are detectable, the dynamic range being from 1 to 200 ppm. The response depends on the relative humidity, and acidic gases including sulphur dioxide, carbon dioxide, and nitric oxides are found to reduce the relative signal change caused by ammonia, whilst in the absence of ammonia they remain inert. Aging of the film is observed within a few months after film preparation.},
  langid = {english},
  keywords = {ammonia determination,integrated optics,laser spectroscopy,optical sensor,optical waveguide},
  file = {/Users/radek/Zotero/storage/KDDYCX4K/Brandenburg et al. - 1995 - Ammonia detection via integrated optical evanescen.pdf}
}

@misc{AfetftBGsaoBc_SadakaEtAl_2023,
  title = {A Finite Element Toolbox for the {{Bogoliubov-de Gennes}} Stability Analysis of {{Bose-Einstein}} Condensates},
  author = {Sadaka, Georges and Kalt, Victor and Danaila, Ionut and Hecht, Fr{\'e}d{\'e}ric},
  year = 2023,
  month = mar,
  number = {arXiv:2303.05350},
  eprint = {2303.05350},
  primaryclass = {cond-mat},
  publisher = {arXiv},
  urldate = {2024-02-05},
  abstract = {We present a finite element toolbox for the computation of Bogoliubov-de Gennes modes used to assess the linear stability of stationary solutions of the Gross-Pitaevskii (GP) equation. Applications concern one (single GP equation) or two-component (a system of coupled GP equations) Bose-Einstein condensates in one, two and three dimensions of space. An implementation using the free software FreeFem++ is distributed with this paper. For the computation of the GP stationary (complex or real) solutions we use a Newton algorithm coupled with a continuation method exploring the parameter space (the chemical potential or the interaction constant). Bogoliubov-de Gennes equations are then solved using dedicated libraries for the associated eigenvalue problem. Mesh adaptivity is proved to considerably reduce the computational time for cases implying complex vortex states. Programs are validated through comparisons with known theoretical results for simple cases and numerical results reported in the literature.},
  archiveprefix = {arXiv},
  langid = {english},
  keywords = {Bogolibov,Condensed Matter - Quantum Gases},
  file = {/Users/radek/Downloads/Lecture_3.pdf;/Users/radek/Zotero/storage/6U7PUW9K/Sadaka et al. - 2023 - A finite element toolbox for the Bogoliubov-de Gen.pdf}
}

@article{Ai__2024,
  title = {Auditory Illusion},
  year = 2024,
  month = jun,
  journal = {Wikipedia},
  urldate = {2025-01-05},
  abstract = {Auditory illusions are illusions of real sound or outside stimulus. These false perceptions are the equivalent of an optical illusion: the listener hears either sounds which are not present in the stimulus, or sounds that should not be possible given the circumstance on how they were created. Humans are fairly susceptible to illusions, despite an innate ability to process complex stimuli. Confirmation bias is believed to be largely responsible for the inaccurate judgments that people make when evaluating information, given that humans typically interpret and recall information that appeals to their own biases. Amongst these misinterpretations, known as illusions, falls the category of auditory illusions. The brain uses multiple senses simultaneously to process information,  spatial information is processed with greater detail and accuracy in vision than in hearing.  Auditory illusions highlight areas where the human ear and brain, as organic survival tools, differentiate from perfect audio receptors; this shows that it is possible for a human being to hear something that is not there and be able to react to the sound they supposedly heard. When someone is experiencing an auditory illusion, their brain is falsely interpreting its surroundings and distorting their perception of the world around them.},
  copyright = {Creative Commons Attribution-ShareAlike License},
  langid = {english},
  annotation = {Page Version ID: 1226796121},
  file = {/Users/radek/Zotero/storage/PKVSUT3K/Auditory_illusion.html}
}

@article{Aiacoavc_ChiEtAl_2020,
