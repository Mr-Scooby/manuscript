  author = {Harrer, Andreas and Szedlak, Rolf and Schwarz, Benedikt and Moser, Harald and Zederbauer, Tobias and MacFarland, Donald and Detz, Hermann and Andrews, Aaron Maxwell and Schrenk, Werner and Lendl, Bernhard and Strasser, Gottfried},
