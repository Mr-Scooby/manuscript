@article{MqsoasBciadp_WangEtAl_2018,
  title = {Macroscopic Quantum Self-Trapping of a Spin--Orbit-Coupled {{Bose}}--{{Einstein}} Condensate in a Double-Well Potential},
  author = {Wang, Wen-Yuan and Dou, Fu-Quan and Duan, Wen-Shan},
  year = 2018,
